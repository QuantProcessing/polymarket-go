# ============================================================
# Polymarket Go SDK - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Wallet ---
# EOA private key (Hex, with 0x prefix). Required for signing orders and on-chain transactions.
POLY_PRIVATE_KEY=0x...

# Gnosis Safe proxy address. Optional: enables EIP-1271 proxy signing.
POLY_FUNDER_ADDR=0x...

# --- CLOB API Credentials ---
# Obtain from Polymarket CLOB. Used for WebSocket auth and higher rate limits.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# --- Blockchain ---
# Polygon RPC endpoint. Required for on-chain operations (CTF split/merge/redeem).
POLY_RPC_URL=https://polygon-rpc.com

# --- Network ---
# HTTP/SOCKS5 proxy URL. Optional: used by Data API client.
# PROXY=http://127.0.0.1:7890

# --- Testing ---
# Set to "true" to enable integration tests that spend real funds.
# ENABLE_SPEND_TESTS=false
